{
  "name": "supaforge",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "dev:api": "npm --workspace api run start:dev",
    "dev:web": "npm --workspace web run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
